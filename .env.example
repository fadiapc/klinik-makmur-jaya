# ─────────────────────────────────────────────────────────
#  Klinik Makmur Jaya — Backend Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env to source control.
# ─────────────────────────────────────────────────────────

# Application
APP_NAME="Klinik Makmur Jaya E-Commerce API"
APP_VERSION="1.0.0"
ENVIRONMENT=development
DEBUG=true

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=klinik_makmur_jaya
DATABASE_USER=postgres
DATABASE_PASSWORD=your_strong_password_here

# SQLAlchemy pool (tune for production)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=2

# Email (Mailtrap for development)
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_FROM=noreply@klinikmakmurjaya.id
MAIL_PORT=587
MAIL_SERVER=smtp.mailtrap.io
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# CORS allowed origins (comma-separated list)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Frontend base URL (used in email verification links)
FRONTEND_URL=http://localhost:5173
